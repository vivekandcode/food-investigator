# Default API Keys (leave blank if you want users to enter their own)
# These are fallback keys — users can override in the app settings

# Groq API Key (free at console.groq.com)
VITE_GROQ_API_KEY=

# Google Gemini API Key (free at aistudio.google.com)
VITE_GEMINI_API_KEY=

# OpenRouter API Key (free at openrouter.ai)
VITE_OPENROUTER_API_KEY=

# Mistral API Key (free at console.mistral.ai)
VITE_MISTRAL_API_KEY=

# Default model provider: groq | gemini | openrouter | mistral
VITE_DEFAULT_PROVIDER=groq
